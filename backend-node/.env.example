# ============================================
# .env.example — Copy to .env and fill in values
# ============================================

NODE_ENV=development
PORT=3000

# SQLite database file path (relative to backend-node/)
DATABASE_PATH=./data/database.sqlite
SESSION_DB_PATH=./data/sessions.sqlite

# Session — REQUIRED in production (min 32 characters)
SESSION_SECRET=change_this_to_a_long_random_string_at_least_32_chars

# CORS — comma-separated origins, or * for all (dev only)
# CORS_ORIGINS=http://localhost:3000,http://127.0.0.1:3000
CORS_ORIGINS=

# Auth rate limit (requests per 15 min window)
AUTH_RATE_LIMIT_MAX=20

# Logging: debug | info | warn | error
LOG_LEVEL=debug
